DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-strong-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

LOG_LEVEL=INFO

# Django ORM database file. The ORM is used ONLY for Django's built-in
# auth/migration tables; all business data (embeddings, forecasts, segments)
# lives in DynamoDB. Override the path in deployments with a writable volume.
SQLITE_PATH=/tmp/ai_service.sqlite3

# JWT (RS256) — verifies tokens signed by the Go core backend
JWT_PUBLIC_KEY_PATH=/app/.tools/keys/jwt_public_dev.pem
JWT_ISSUER=ficct-go
JWT_AUDIENCE=ficct-django

# DynamoDB Local
DYNAMODB_ENDPOINT=http://dynamodb:8000
DYNAMODB_REGION=us-east-1
DYNAMODB_ACCESS_KEY_ID=local
DYNAMODB_SECRET_ACCESS_KEY=local
DYNAMODB_TABLE_PREFIX=ficct_

CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:19006,exp://localhost:19000

# Go core API (for catalog sync)
GO_CORE_BASE_URL=http://host.docker.internal:8080
GO_CORE_TIMEOUT_SECONDS=30
