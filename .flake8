[flake8]
max-line-length = 100
extend-ignore =
    E203,
    W503,
    E501
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    migrations,
    staticfiles,
    media,
    .tools,
    build,
    dist,
    *.egg-info
per-file-ignores =
    __init__.py:F401
    apps/*/migrations/*:E501,F401
